# Cloudflare Pages cache rules
# https://developers.cloudflare.com/pages/configuration/headers/

# index.html — never cache; browser always re-fetches to get latest chunk hashes
/index.html
  Cache-Control: no-store, no-cache, must-revalidate
  X-Content-Type-Options: nosniff

# Vite build output — hashed filenames are immutable; cache for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# pdfjs worker — served as .js so Cloudflare sets Content-Type: application/javascript.
# Versioned alongside the app deploy so a 24-hour cache is safe.
/pdf.worker.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600
  Content-Type: application/javascript; charset=utf-8

# Static images in /images
/images/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

# favicon
/favicon.png
  Cache-Control: public, max-age=86400

# robots.txt — short cache
/robots.txt
  Cache-Control: public, max-age=3600

# All other routes (SPA fallback) — never cache HTML
/*
  Cache-Control: no-store, no-cache, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
